REDIS_URL=redis://localhost:6379
GEOIP_DB_PATH=./GeoLite2-City.mmdb
IDS_API_KEY=change-me-secret
ALERT_WEBHOOK_URL=
# Risk score thresholds
RISK_BLOCK_THRESHOLD=80
RISK_ALERT_THRESHOLD=50
# Rate limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100
BRUTE_FORCE_MAX=5
BRUTE_FORCE_WINDOW=300
# IPS (Intrusion Prevention System)
IPS_ENABLED=true
IPS_AUTO_BLOCK_TTL=3600
# Email alerts
# Option A — Resend HTTP API (recommended on Render / cloud, no SMTP port issues)
RESEND_API_KEY=
# Option B — SMTP (works on local / unrestricted hosts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Shared by both options
SMTP_FROM=
ALERT_EMAIL_TO=
# Email resolution links — set to the externally reachable base URL of this service (no trailing slash)
# e.g. https://ids.example.com or http://localhost:8000
RESOLUTION_BASE_URL=http://localhost:8000
# How long email action links stay valid (seconds). Default: 86400 (24h)
RESOLUTION_TOKEN_TTL=86400
